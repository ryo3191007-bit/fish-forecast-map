{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fish-forecast-map.example/schemas/fishing-spot-research.schema.json",
  "title": "Fishing spot research record",
  "description": "複数の公開情報源から独立調査した釣り場属性を、根拠・確認状態・確度とともに保持する。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "spotId",
    "identity",
    "attributes",
    "fishSpecies",
    "facilities",
    "restrictions",
    "sources",
    "researchNotes",
    "researchedAt",
    "reviewStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "spotId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spotName",
        "aliases",
        "prefecture",
        "municipality",
        "coordinates"
      ],
      "properties": {
        "spotName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "uniqueItems": true
        },
        "prefecture": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20
        },
        "municipality": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "coordinates": {
          "$ref": "#/$defs/coordinates"
        }
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spotType",
        "seabed",
        "waterDepth",
        "riverInfluence",
        "tidalFlow",
        "streetLights",
        "obstacles",
        "openSeaExposure",
        "fishingRange"
      ],
      "properties": {
        "spotType": {
          "$ref": "#/$defs/spotTypeEvidence"
        },
        "seabed": {
          "$ref": "#/$defs/seabedEvidence"
        },
        "waterDepth": {
          "$ref": "#/$defs/waterDepthEvidence"
        },
        "riverInfluence": {
          "$ref": "#/$defs/riverInfluenceEvidence"
        },
        "tidalFlow": {
          "$ref": "#/$defs/tidalFlowEvidence"
        },
        "streetLights": {
          "$ref": "#/$defs/streetLightsEvidence"
        },
        "obstacles": {
          "$ref": "#/$defs/obstaclesEvidence"
        },
        "openSeaExposure": {
          "$ref": "#/$defs/openSeaExposureEvidence"
        },
        "fishingRange": {
          "$ref": "#/$defs/fishingRangeEvidence"
        }
      }
    },
    "fishSpecies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fishSpeciesEvidence"
      }
    },
    "facilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parking",
        "toilet"
      ],
      "properties": {
        "parking": {
          "$ref": "#/$defs/availabilityEvidence"
        },
        "toilet": {
          "$ref": "#/$defs/availabilityEvidence"
        }
      }
    },
    "restrictions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fishingProhibited",
        "entryProhibited",
        "constructionOrClosure",
        "officialContact"
      ],
      "properties": {
        "fishingProhibited": {
          "$ref": "#/$defs/restrictionEvidence"
        },
        "entryProhibited": {
          "$ref": "#/$defs/restrictionEvidence"
        },
        "constructionOrClosure": {
          "$ref": "#/$defs/restrictionEvidence"
        },
        "officialContact": {
          "$ref": "#/$defs/officialContact"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "researchNotes": {
      "type": "string",
      "maxLength": 5000
    },
    "researchedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "needs_revision"
      ]
    },
    "review": {
      "$ref": "#/$defs/review"
    }
  },
  "$defs": {
    "researchStatus": {
      "type": "string",
      "enum": [
        "confirmed",
        "inferred",
        "unknown"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "sourceIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidenceBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "status",
        "confidence",
        "sourceIds",
        "checkedAt"
      ],
      "properties": {
        "value": {},
        "status": {
          "$ref": "#/$defs/researchStatus"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sourceIds": {
          "$ref": "#/$defs/sourceIds"
        },
        "checkedAt": {
          "type": "string",
          "format": "date"
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "confirmed",
                  "inferred"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "sourceIds": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "confidence": {
                "const": "low"
              }
            }
          }
        }
      ]
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latitude",
        "longitude",
        "status",
        "confidence",
        "sourceIds",
        "checkedAt"
      ],
      "properties": {
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -180,
          "maximum": 180
        },
        "status": {
          "$ref": "#/$defs/researchStatus"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sourceIds": {
          "$ref": "#/$defs/sourceIds"
        },
        "checkedAt": {
          "type": "string",
          "format": "date"
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "latitude": {
                "type": "null"
              },
              "longitude": {
                "type": "null"
              },
              "confidence": {
                "const": "low"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "confirmed",
                  "inferred"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              },
              "sourceIds": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "spotTypeValue": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "port",
          "fishing_port",
          "breakwater",
          "revetment",
          "sandy_beach",
          "rocky_shore",
          "river_mouth",
          "fishing_facility",
          "mixed",
          "unknown"
        ]
      },
      "allOf": [
        {
          "if": {
            "contains": {
              "const": "unknown"
            }
          },
          "then": {
            "maxItems": 1
          }
        },
        {
          "if": {
            "contains": {
              "const": "mixed"
            }
          },
          "then": {
            "maxItems": 1
          }
        }
      ]
    },
    "seabedValue": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "sand",
          "mud",
          "rock",
          "seaweed",
          "mixed",
          "unknown"
        ]
      },
      "allOf": [
        {
          "if": {
            "contains": {
              "const": "unknown"
            }
          },
          "then": {
            "maxItems": 1
          }
        },
        {
          "if": {
            "contains": {
              "const": "mixed"
            }
          },
          "then": {
            "maxItems": 1
          }
        }
      ]
    },
    "waterDepthValue": {
      "type": "string",
      "enum": [
        "shallow",
        "moderate",
        "deep",
        "unknown"
      ]
    },
    "riverInfluenceValue": {
      "type": "string",
      "enum": [
        "none",
        "weak",
        "strong",
        "unknown"
      ]
    },
    "tidalFlowValue": {
      "type": "string",
      "enum": [
        "weak",
        "moderate",
        "strong",
        "unknown"
      ]
    },
    "streetLightsValue": {
      "type": "string",
      "enum": [
        "present",
        "absent",
        "unknown"
      ]
    },
    "obstaclesValue": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "tetrapods",
          "rocks",
          "seaweed",
          "bridge_piers",
          "wave_dissipating_blocks",
          "other",
          "none",
          "unknown"
        ]
      },
      "allOf": [
        {
          "if": {
            "contains": {
              "const": "unknown"
            }
          },
          "then": {
            "maxItems": 1
          }
        },
        {
          "if": {
            "contains": {
              "const": "none"
            }
          },
          "then": {
            "maxItems": 1
          }
        }
      ]
    },
    "openSeaExposureValue": {
      "type": "string",
      "enum": [
        "inner_bay",
        "bay",
        "bay_mouth",
        "open_sea",
        "unknown"
      ]
    },
    "fishingRangeValue": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "foot",
          "near",
          "long_cast",
          "unknown"
        ]
      },
      "allOf": [
        {
          "if": {
            "contains": {
              "const": "unknown"
            }
          },
          "then": {
            "maxItems": 1
          }
        }
      ]
    },
    "availabilityValue": {
      "type": "string",
      "enum": [
        "available",
        "not_available",
        "unknown"
      ]
    },
    "restrictionValue": {
      "type": "string",
      "enum": [
        "yes",
        "no",
        "partial",
        "unknown"
      ]
    },
    "spotTypeEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/spotTypeValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": [
                  "unknown"
                ]
              }
            }
          }
        }
      ]
    },
    "seabedEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/seabedValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": [
                  "unknown"
                ]
              }
            }
          }
        }
      ]
    },
    "waterDepthEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/waterDepthValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "riverInfluenceEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/riverInfluenceValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "tidalFlowEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/tidalFlowValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "streetLightsEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/streetLightsValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "obstaclesEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/obstaclesValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": [
                  "unknown"
                ]
              }
            }
          }
        }
      ]
    },
    "openSeaExposureEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/openSeaExposureValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "fishingRangeEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/fishingRangeValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": [
                  "unknown"
                ]
              }
            }
          }
        }
      ]
    },
    "availabilityEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/availabilityValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "restrictionEvidence": {
      "allOf": [
        {
          "$ref": "#/$defs/evidenceBase"
        },
        {
          "properties": {
            "value": {
              "$ref": "#/$defs/restrictionValue"
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "fishSpeciesEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "basis",
        "status",
        "confidence",
        "sourceIds",
        "checkedAt"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "basis": {
          "type": "string",
          "enum": [
            "observed",
            "expected"
          ]
        },
        "status": {
          "$ref": "#/$defs/researchStatus"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sourceIds": {
          "$ref": "#/$defs/sourceIds"
        },
        "checkedAt": {
          "type": "string",
          "format": "date"
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "basis": {
                "const": "observed"
              }
            },
            "required": [
              "basis"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "confirmed"
              },
              "sourceIds": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "basis": {
                "const": "expected"
              }
            },
            "required": [
              "basis"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "inferred"
              },
              "sourceIds": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "officialContact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url",
        "checkedAt"
      ],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "checkedAt": {
          "type": "string",
          "format": "date"
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "url",
        "title",
        "publisher",
        "sourceType",
        "checkedAt",
        "supports"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^src-[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "publisher": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "government",
            "port_manager",
            "fisheries_cooperative",
            "coast_guard",
            "public_map",
            "research_institute",
            "facility_official",
            "news_media",
            "private_reference",
            "personal_blog",
            "social_media"
          ]
        },
        "checkedAt": {
          "type": "string",
          "format": "date"
        },
        "publishedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(identity|attributes|fishSpecies|facilities|restrictions)(\\.[A-Za-z0-9_-]+)+$"
          },
          "uniqueItems": true
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewedAt",
        "reviewer",
        "issues"
      ],
      "properties": {
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "reviewer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    }
  }
}
