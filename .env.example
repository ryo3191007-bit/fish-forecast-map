# Supabase public client settings
# NEXT_PUBLIC_* values can be exposed to the browser.
# Use dummy values here. Put real values in .env.local or Vercel Environment Variables.
NEXT_PUBLIC_SUPABASE_URL="https://example-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="example-anon-key"

# Server-only Supabase settings
# Do not expose these to the browser. Do not commit real values.
# Leave unused until a server-side feature needs them.
SUPABASE_SERVICE_ROLE_KEY="example-service-role-key-do-not-use"
SUPABASE_DB_URL="postgresql://example-user:example-password@example-host:5432/example-db"
